# Environment variables for local development
# Copy to .env and fill in values

# GitHub OAuth App — create one at https://github.com/settings/applications/new
# Set "Authorization callback URL" to http://localhost:5173
VITE_GITHUB_CLIENT_ID=

# Repository where agent data lives (owner/repo)
VITE_REPO_OWNER=evpeaire
VITE_REPO_NAME=AgentHub

# Giscus (GitHub Discussions comments) — configure at https://giscus.app
VITE_GISCUS_REPO=
VITE_GISCUS_REPO_ID=
VITE_GISCUS_CATEGORY_ID=
